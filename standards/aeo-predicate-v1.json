{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "predicateType",
    "subject",
    "continuity_id",
    "trace_id",
    "validity"
  ],
  "properties": {
    "predicateType": {
      "type": "string",
      "const": "mindshift.aeo.v1"
    },
    "purpose": {
      "type": "string",
      "const": "Exact executable legitimacy object; executable predicates require nonce, replay scope, duplicate hash detection, revocation checks, and validated_object == executed_object."
    },
    "subject": {
      "type": "array"
    },
    "continuity_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "payload_hash": {
      "type": "string"
    },
    "replay": {
      "type": "object"
    },
    "revocation": {
      "type": "object"
    },
    "validity": {
      "type": "string",
      "enum": [
        "VALID",
        "NULL"
      ]
    }
  },
  "$id": "https://mindshift.local/standards/aeo-predicate-v1.json",
  "title": "mindshift.aeo.v1"
}
