{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindshift.local/schemas/skill_surfaces_registry_v1.json",
  "title": "SKILL_SURFACES_REGISTRY_V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entries"],
  "properties": {
    "schema_version": { "const": "SKILL_SURFACES_REGISTRY_V1" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "skill_id",
          "surface_type",
          "risk_class",
          "mutation_capable",
          "allowed_targets",
          "required_validator_layers",
          "proof_requirements",
          "replay_domain"
        ],
        "properties": {
          "skill_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$", "minLength": 3 },
          "surface_type": {
            "type": "string",
            "enum": ["observability", "repository_mutation", "deploy_capable", "runtime_mutation", "other"]
          },
          "risk_class": { "type": ["string", "null"] },
          "mutation_capable": { "type": "boolean" },
          "allowed_targets": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }
          },
          "required_validator_layers": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }
          },
          "proof_requirements": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }
          },
          "replay_domain": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }
        }
      }
    }
  }
}
