    "undeclared_mutation_surface",
    "missing_declared_surface",
    "authority_surface_mismatch",
    "bypass_path_mismatch",
    "trust_boundary_mismatch",
    "federation_authority_inheritance",
    "policy_graph_mismatch",
    "runtime_graph_hash_mismatch"
  ],
  "forbidden_behavior": [
    "runtime_state_mutation",
    "authority_creation",
    "proof_creation",
    "execution_triggering",
    "remote_authority_inheritance"
  ],
  "failure_mode": "NULL"
