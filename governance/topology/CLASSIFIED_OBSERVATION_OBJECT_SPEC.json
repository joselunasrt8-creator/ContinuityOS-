            "end": "2026-05-30T10:12:45Z"
          },
          "reconstruction_sources": ["authority_registry", "revocation_log"]
        }
      },
      "non_operability": {
        "creates_validity": false,
        "creates_authority": false,
        "creates_execution_eligibility": false,
        "creates_reconciliation_closure": false
      }
    }
  ],
  "forbidden_raw_state_examples": [
    {
      "label": "forbidden_raw_state_no_classification",
      "forbidden": { "state": "DEPLOYMENT_ACTIVE" },
      "reason": "Raw state without classification metadata. Remote nodes may incorrectly infer DEPLOYMENT_ACTIVE -> LEGITIMATE. This creates a legitimacy jump."
    },
    {
      "label": "forbidden_legitimacy_in_summary",
      "forbidden": {
        "evidence": {
          "summary": {
            "replay_safe": true,
            "execution_eligible": true
          }
        }
      },
      "reason": "Summary interprets legitimacy instead of describing evidence."
    }
  ],
  "downgrade_semantics": {
    "description": "Observations must be downgraded when certainty cannot be supported by evidence.",
    "rules": [
      {
        "condition": "lineage_hash missing",
        "result": "OBSERVATION_OBJECT_INVALID — do not emit"
      },
      {
        "condition": "lineage_status = MISSING, verification_status = UNVERIFIED",
        "classification": "TOPOLOGY_PARTIAL or TOPOLOGY_UNOBSERVABLE",
        "non_operability_all_false": true,
        "note": "Active state with missing lineage must not propagate as verified."
      },
      {
        "condition": "unverified revocation signal received",
        "classification": "TOPOLOGY_CONFLICTED",
        "evidence_type": "AUTHORITY_STATE",
        "summary_observed_state": "REVOCATION_SIGNAL_UNVERIFIED",
        "note": "Must not cause false topology-wide invalidation. Reconciliation layer decides."
      },
      {
        "condition": "conflicting observations for same surface",
        "classification": "TOPOLOGY_CONFLICTED",
        "gap_reconciliation_status": "UNBRIDGEABLE",
        "note": "Cannot produce closure until conflict resolves."
      },
      {
        "condition": "topology_view_id missing",
        "result": "OBSERVATION_OBJECT_INVALID — do not emit"
      }
    ]
  },
  "determinism_requirements": {
    "rule": "Identical observation_id, lineage_hash, topology_view_id, classification, and evidence_hash must produce an identical observation hash.",
    "mutation_rules": [
      "Change to lineage_hash must change observation hash.",
      "Change to topology_view_id must change observation hash.",
      "Change to evidence_hash must change observation hash."
    ],
    "hash_input_fields": [
      "observation_id",
      "lineage_hash",
      "topology_view_id",
      "classification",
      "evidence.evidence_hash"
    ]
  },
  "relationship_to_1640": {
    "summary": "#1640 defines what may be observed. #1641 defines the canonical object used to observe it. #1642 defines when that object may emit.",
    "#1640_provides": [
      "topology-relevant observation inventory",
      "observation category taxonomy",
      "propagation constraints",
      "evidence precedence hierarchy",
      "gap bridgeability semantics"
    ],
    "#1641_provides": [
      "canonical Classified Observation Object shape",
      "allowed enum values",
      "required certainty fields",
      "propagation-safe examples",
      "forbidden raw-state examples",
      "downgrade semantics",
      "non-authoritative boundaries",
      "deterministic hashing definition"
    ],
    "#1642_will_provide": [
      "emission trigger model",
      "selective emission logic",
      "stability window semantics"
    ]
  },
  "planning_questions_answered": {
    "1_mandatory_fields_for_all_observations": [
      "observation_id",
      "lineage_hash",
      "topology_view_id",
      "object_type",
      "schema_version",
      "observer_id",
      "observed_at",
      "classification",
      "target_surface",
      "evidence",
      "non_operability"
    ],
    "2_optional_but_required_for_governance": [
      "reconciliation_epoch",
      "evidence.raw_evidence_ref",
      "evidence.topology_gap (required when evidence_type = TOPOLOGY_GAP)"
    ],
    "3_classifications_affecting_execution_eligibility": "None directly. All classifications are visibility states only. Execution eligibility is determined by the reconciliation layer, not by observation objects.",
    "4_statuses_requiring_reconciliation_before_propagation": [
      "TOPOLOGY_CONFLICTED — requires reconciliation to resolve conflict",
      "TOPOLOGY_UNOBSERVABLE — requires reconciliation or gap bridging",
      "gap_reconciliation_status = UNKNOWN — cannot produce closure",
      "gap_reconciliation_status = UNBRIDGEABLE — cannot produce closure"
    ],
    "5_unverified_revocation_signals": "Classify as TOPOLOGY_CONFLICTED with evidence_type = AUTHORITY_STATE and summary.observed_state = REVOCATION_SIGNAL_UNVERIFIED. Do not cascade as AUTHORITY_INVALID. Reconciliation layer decides after verification.",
    "6_active_state_with_missing_lineage": "Classify as TOPOLOGY_PARTIAL with evidence_type matching the surface, summary.observed_state = <active_state>, summary.lineage_status = MISSING. The non_operability block ensures all flags remain false."
  }
}
